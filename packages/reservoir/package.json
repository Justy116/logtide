{
  "name": "@logtide/reservoir",
  "version": "1.0.1",
  "description": "Pluggable storage abstraction for Logtide log management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./engines/timescale": {
      "types": "./dist/engines/timescale/index.d.ts",
      "import": "./dist/engines/timescale/index.js"
    },
    "./engines/clickhouse": {
      "types": "./dist/engines/clickhouse/index.d.ts",
      "import": "./dist/engines/clickhouse/index.js"
    },
    "./engines/mongodb": {
      "types": "./dist/engines/mongodb/index.d.ts",
      "import": "./dist/engines/mongodb/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "bench": "tsx benchmark/run.ts",
    "bench:logs": "tsx benchmark/run.ts -s logs",
    "bench:spans": "tsx benchmark/run.ts -s spans",
    "bench:metrics": "tsx benchmark/run.ts -s metrics",
    "bench:quick": "tsx benchmark/run.ts -v 1k,10k -i 3 -w 1",
    "bench:full": "tsx benchmark/run.ts -v 1k,10k,100k,1m,10m,50m",
    "bench:infra": "docker compose -f benchmark/docker-compose.benchmark.yml up -d",
    "bench:infra:down": "docker compose -f benchmark/docker-compose.benchmark.yml down -v"
  },
  "dependencies": {
    "@clickhouse/client": "^1.17.0",
    "@logtide/shared": "workspace:*",
    "mongodb": "^6.21.0"
  },
  "peerDependencies": {
    "pg": "^8.11.0",
    "ioredis": "^5.4.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@vitest/coverage-v8": "^3.2.6",
    "ioredis": "^5.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "logs",
    "storage",
    "timescaledb",
    "clickhouse",
    "observability",
    "abstraction"
  ],
  "license": "AGPL-3.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
