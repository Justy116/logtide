{
  "name": "@logtide/backend",
  "version": "1.0.3",
  "private": true,
  "description": "LogTide Backend API",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "migrate": "tsx src/scripts/migrate.ts",
    "migrate:down": "tsx src/scripts/migrate.ts down",
    "migrate:cleanup": "tsx src/scripts/cleanup-old-migrations.ts",
    "check-schema": "tsx src/scripts/check-schema.ts",
    "enable-system-login": "tsx src/scripts/enable-system-login.ts",
    "add-system-to-org": "tsx src/scripts/add-system-to-org.ts",
    "test": "node src/scripts/run-tests.mjs",
    "test:watch": "node src/scripts/run-tests.mjs --watch",
    "test:coverage": "node src/scripts/run-tests.mjs --coverage",
    "test:ci": "vitest run",
    "test:ci:coverage": "vitest run --coverage",
    "typecheck": "pnpm --filter @logtide/shared --filter @logtide/reservoir build && tsc --noEmit",
    "clean": "rm -rf dist",
    "load:smoke": "k6 run load-tests/smoke.js",
    "load:ingestion": "k6 run load-tests/ingestion.js",
    "load:query": "k6 run load-tests/query.js",
    "load:buffered-vs-sync": "k6 run load-tests/buffered-vs-sync.js",
    "load:e2e:smoke": "bash scripts/run-load-tests.sh smoke",
    "load:e2e:ingestion": "bash scripts/run-load-tests.sh ingestion",
    "load:e2e:query": "bash scripts/run-load-tests.sh query",
    "load:e2e:all": "bash scripts/run-load-tests.sh all",
    "seed:load-test": "tsx src/scripts/seed-load-test.ts",
    "seed:massive": "tsx src/scripts/seed-massive-data.ts",
    "migrate:storage": "tsx src/scripts/migrate-storage.ts",
    "check:tenant-scoping": "tsx scripts/check-tenant-scoping.ts",
    "report:tenant-scoping": "tsx scripts/check-tenant-scoping.ts --report"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/env": "^5.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/websocket": "^11.0.2",
    "@logtide/core": "0.7.0",
    "@logtide/fastify": "0.7.0",
    "@logtide/reservoir": "workspace:*",
    "@logtide/shared": "workspace:*",
    "@maxmind/geoip2-node": "^6.3.4",
    "@opentelemetry/otlp-transformer": "^0.208.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.65.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.0.1",
    "graphile-worker": "^0.16.6",
    "ioredis": "^5.8.2",
    "js-yaml": "^4.2.0",
    "kysely": "^0.28.17",
    "ldapts": "^7.2.1",
    "maxmind": "^5.0.1",
    "nodemailer": "^9.0.1",
    "openid-client": "^6.4.1",
    "pg": "^8.16.3",
    "protobufjs": "^7.6.3",
    "safe-regex2": "^5.0.0",
    "source-map": "^0.7.6",
    "tsx": "^4.21.0",
    "undici": "^7.28.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.25",
    "@types/nodemailer": "^6.4.21",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.6",
    "supertest": "^7.1.4",
    "ts-morph": "^28.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}