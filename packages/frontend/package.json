{
  "name": "@logtide/frontend",
  "version": "1.0.0",
  "private": true,
  "description": "LogTide Frontend Dashboard",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "cross-env E2E=true playwright test",
    "test:e2e:headed": "cross-env E2E=true playwright test --headed",
    "test:e2e:debug": "cross-env E2E=true playwright test --debug",
    "test:e2e:ui": "cross-env E2E=true playwright test --ui",
    "test:journeys": "cross-env E2E=true playwright test tests/journeys",
    "test:edge-cases": "cross-env E2E=true playwright test tests/edge-cases",
    "typecheck": "svelte-kit sync && tsc --noEmit",
    "clean": "rm -rf .svelte-kit build test-results",
    "sourcemaps:upload": "logtide sourcemaps upload build/client --release $npm_package_version"
  },
  "dependencies": {
    "@logtide/core": "0.7.0",
    "@logtide/shared": "workspace:*",
    "@logtide/sveltekit": "0.7.0",
    "@lucide/svelte": "^0.482.0",
    "@tanstack/svelte-table": "^8.21.3",
    "canvas-confetti": "^1.9.4",
    "echarts": "^6.0.0",
    "leaflet": "^1.9.4",
    "shiki": "^3.18.0",
    "svelte-dnd-action": "^0.9.69",
    "web-vitals": "^4.0.0"
  },
  "devDependencies": {
    "@logtide/cli": "0.7.0",
    "@playwright/test": "^1.57.0",
    "@prgm/sveltekit-progress-bar": "^3.0.2",
    "@sveltejs/adapter-node": "^5.4.0",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/leaflet": "^1.9.21",
    "autoprefixer": "^10.4.22",
    "bits-ui": "^1.8.0",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "csstype": "^3.2.3",
    "jsdom": "^29.1.1",
    "mode-watcher": "^1.1.0",
    "postcss": "^8.5.10",
    "shadcn-svelte": "^1.0.12",
    "svelte": "^5.55.7",
    "svelte-sonner": "^0.3.28",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^0.2.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
